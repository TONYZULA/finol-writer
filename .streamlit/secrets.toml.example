# Streamlit Secrets Configuration Template
# Copy this file to .streamlit/secrets.toml and fill in your API keys

# ============================================================================
# REQUIRED API KEYS
# ============================================================================

# Tavily API - Required for web research
# Get your key at: https://tavily.com
TAVILY_API_KEY = "tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Templated.io API - Required for cover image generation
# Get your key at: https://templated.io
TEMPLATED_API_KEY = "tmp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================================================
# AI PROVIDER API KEYS (At least one required for fallback system)
# ============================================================================

# Bytez API - Free tier with 70+ models (RECOMMENDED)
# Default free tier key provided, or get your own at: https://bytez.com/api
BYTEZ_API_KEY = "444d1ac0a8b038cbe61ff956a8cdd700"

# Google Gemini API - Optional but recommended
# Get your key at: https://aistudio.google.com/app/apikeys
GOOGLE_API_KEY = "AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# OpenRouter API - Optional, provides 30+ free models
# Get your key at: https://openrouter.ai
OPENROUTER_API_KEY = "sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================================================
# OPTIONAL CONFIGURATION
# ============================================================================

# OpenRouter API Base URL (only change if using proxy)
OPENROUTER_API_BASE = "https://openrouter.ai/api/v1"

# OpenRouter Site URL (for rankings on openrouter.ai)
OR_SITE_URL = "https://yourwebsite.com"

# OpenRouter App Name (for rankings on openrouter.ai)
OR_APP_NAME = "FINOL Blog Writer"

# ============================================================================
# NOTES
# ============================================================================
# 
# Minimum Configuration:
# - TAVILY_API_KEY (required)
# - TEMPLATED_API_KEY (required)
# - At least one AI provider key (BYTEZ_API_KEY is pre-configured)
#
# Recommended Configuration:
# - All of the above
# - GOOGLE_API_KEY (for best quality)
# - OPENROUTER_API_KEY (for variety)
#
# Fallback Order:
# 1. Gemini (if GOOGLE_API_KEY configured)
# 2. OpenRouter (if OPENROUTER_API_KEY configured)
# 3. Bytez (if BYTEZ_API_KEY configured)
#
# The system automatically tries providers in order until one succeeds.
